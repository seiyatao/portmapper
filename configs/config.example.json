{
  "service_name": "pc-edge-gateway",
  "service_desc": "内部 TCP/UDP 端口映射服务",
  "log_path": "logs/pc-edge-gateway.log",
  "rules": [
    {
      "name": "web-tcp",
      "enabled": true,
      "protocol": "tcp",
      "listen": "0.0.0.0:8080",
      "target": "192.168.1.100:80",
      "timeout_seconds": 300,
      "max_connections": 1000
    },
    {
      "name": "dns-udp",
      "enabled": true,
      "protocol": "udp",
      "listen": "0.0.0.0:5353",
      "target": "192.168.1.101:5353",
      "timeout_seconds": 60,
      "max_connections": 1000
    }
  ]
}
